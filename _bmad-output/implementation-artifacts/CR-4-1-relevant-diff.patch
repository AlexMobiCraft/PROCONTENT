++
++type PostMediaRow = {
++  id: string
++  url: string
++  thumbnail_url: string | null
++  media_type: 'image' | 'video'
++  order_index: number
++  is_cover: boolean
++}
++
++interface InitialData {
++  id: string
++  title: string
++  content?: string | null
