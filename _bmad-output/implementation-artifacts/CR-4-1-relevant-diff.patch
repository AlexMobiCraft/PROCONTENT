++        />
++      </div>
++
++      {/* Media uploader */}
++      <div className="flex flex-col gap-1.5">
++        <span className="text-sm font-medium">Mediji</span>
++        <MediaUploader items={mediaItems} onChange={handleMediaChange} isSubmitting={isSubmitting} />
++        {mediaError && (
