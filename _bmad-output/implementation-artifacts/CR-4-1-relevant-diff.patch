++      </span>
++
++      {item.is_cover && (
++        <span className="ml-auto mr-1 text-xs font-medium text-primary">Naslovnica</span>
++      )}
++
++      <div className={cn('flex gap-1', item.is_cover ? '' : 'ml-auto')}>
++        {/* Set cover button */}
++        <button
