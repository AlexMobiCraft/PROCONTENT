# Нормализация окончаний строк: всегда LF в репозитории
* text=auto eol=lf

# Явное указание для TypeScript/JavaScript/CSS/HTML файлов
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.vtt  text eol=lf

# Бинарные файлы — без нормализации
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
