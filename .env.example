# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (used for metadata and redirects)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
AUTH_SUCCESS_REDIRECT_PATH=/feed

# Stripe (server-side only — НИКОГДА без NEXT_PUBLIC_ префикса!)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_QUARTERLY_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_RATE_LIMIT_MAX=60
STRIPE_WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# Supabase Service Role Key (только серверная сторона, для webhook admin-клиента)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cookie Secret (для HMAC-подписания кеша subscription_status, предотвращает спуфинг через DevTools)
# Используйте: openssl rand -base64 32
COOKIE_SECRET=your-secure-random-secret-here
SUBSCRIPTION_CACHE_TTL_SECONDS=30

# WhatsApp-группа сообщества (onboarding)
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/placeholder

# Resend (email рассылки)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Секретный ключ для вызова API рассылки из Supabase Database Webhook
NOTIFICATION_API_SECRET=your-secure-random-secret-here
